# ---- PHP / App ----
APP_ENV=production
DB_DSN=
DB_USER=
DB_PASS=

# ---- Socket.IO / WebSocket ----
# IMPORTANT:
# - WS_BROADCAST_SECRET must match in BOTH PHP and Node WS runtimes.
# - ORIGIN/WS_ORIGINS should include the exact site origin(s), e.g. https://glitchahitch.com
# - WS_URL is used by browser clients to connect to Socket.IO.
# - WS_HOOK_URL is used by PHP to send broadcast events to the WS hook service.
ORIGIN=https://glitchahitch.com
WS_ORIGINS=https://glitchahitch.com
WS_HOST=127.0.0.1
WS_PORT=4001
WS_HOOK_HOST=127.0.0.1
WS_HOOK_PORT=4002
WS_HOOK_URL=http://127.0.0.1:4002
WS_BROADCAST_SECRET=replace-with-a-long-random-secret

# Frontend Socket.IO endpoint (page script uses this)
WS_URL=http://127.0.0.1:4001

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com


# ---- Mailtrap SMTP ----
MAILTRAP_USER=
MAILTRAP_TOKEN=

MAILTRAP_Authorization=

MAILTRAP_HOST=live.smtp.mailtrap.io
MAILTRAP_PORT=587

# ---- Other Services ----
MAILER_DSN=

TEST_EMAIL_TO=
TEST_EMAIL_FROM=

APP_KEY=replace-with-a-long-random-secret
# used to HMAC reset tokens
